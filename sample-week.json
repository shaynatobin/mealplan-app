  "prep": [
    {
      "emoji": "⏰",
      "title": "Sunday Strategy",
      "body": "Start crockpot beef first (7–8 hrs LOW). While it cooks: batch-bake chicken breasts and salmon on separate sheet pans, cook jasmine rice (rice cooker) and brown rice (stovetop) simultaneously, roast two pans of veg. Boil turkey meatballs last. Portion Shayna's meals separately into smaller containers. Active time: ~65 min.",
      "reheat": "Everything is grab-and-go Mon–Thu. Salmon is best within 3 days — use Tue/Wed first."
    },
    {
      "emoji": "🍗",
      "title": "Chicken Breast (4 lbs)",
      "body": "Season half with garlic powder, Italian herbs, salt, pepper. Season other half with taco spice blend. Bake at 400°F for 22–25 min until 165°F internal temp. Rest 5 min, then slice or shred. Portion: 6oz for Shane, set aside. Fridge life: 5 days.",
      "reheat": "Microwave with damp paper towel, 90 sec at 70% power. Or slice cold onto salad."
    },
    {
      "emoji": "🐟",
      "title": "Salmon Fillets (3 lbs)",
      "body": "Pat dry, season with salt, pepper, lemon zest, garlic. Bake at 400°F for 12–15 min. Do not overcook — just opaque in center. Portion: 7oz for Shane (2 servings), 4oz for Shayna (2 servings). Fridge life: 3 days max.",
      "reheat": "Microwave 60 sec at 60% power, or eat cold/room temp over salad."
    },
    {
      "emoji": "🥩",
      "title": "Crockpot Beef Chuck (3 lbs)",
      "body": "Place beef in crockpot with ½ cup GF beef broth, 1 tbsp cumin, 1 tbsp chili powder, 1 tsp garlic powder, salt, pepper. Cook LOW 7–8 hours. Shred with two forks. Mix in 2 tbsp cooking liquid. Portion: 6oz for Shane (Mon, Thu, Sun), 4oz for Shayna (Mon, Thu, Sun). Fridge life: 5 days.",
      "reheat": "Microwave 90 sec with splash of broth to prevent drying."
    },
    {
      "emoji": "🍚",
      "title": "Rice (All Types)",
      "body": "Jasmine rice: cook 3 cups dry in rice cooker with 4.5 cups water. Brown rice: 2 cups dry on stovetop, 45 min. Farro: 1 cup dry simmered 25 min in salted water. Portion rice into weekly containers. Fridge life: 5 days.",
      "reheat": "Microwave with damp paper towel, 90 sec. Fluff with fork."
    },
    {
      "emoji": "🥦",
      "title": "Roasted Vegetables",
      "body": "Toss broccoli, asparagus, green beans, zucchini with olive oil spray, salt, pepper, garlic powder. Roast at 425°F for 18–22 min on two sheet pans, rotating once. Roast in batches if needed. Keep varieties separate for portioning flexibility. Fridge life: 4 days.",
      "reheat": "Microwave 60 sec, or eat room temp. Re-crisp in air fryer 3 min at 375°F."
    },
    {
      "emoji": "🍖",
      "title": "Turkey Meatballs (2 lbs ground)",
      "body": "Mix ground turkey with 1 egg, ¼ cup GF breadcrumbs or almond flour, garlic powder, Italian seasoning, salt, pepper. Roll into 1.5oz balls (~20 total). Bake 400°F for 18–20 min or until 165°F. Portion: 7oz for Shane (2 servings), set Shayna's aside for salad. Fridge life: 4 days.",
      "reheat": "Microwave 75 sec with splash of marinara sauce to keep moist."
    }
  ]
}
